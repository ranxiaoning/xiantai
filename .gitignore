# Keep the Godot source project reproducible from a fresh clone.
# Do not ignore assets/, *.import, *.uid, scenes/, scripts/, theme/, or project.godot.

# Local Godot editor/import cache. Godot regenerates these.
.godot/
.import/

# Local Godot editor/runtime binaries and exported builds.
# The source project is expected to run with an installed/local Godot executable.
Godot_v*.exe
godot*.exe
*.exe
*.pck
*.apk
*.ipa
*.dmg
*.app/
exports/
export/
builds/
dist/

# Export presets can contain local paths or signing credentials.
export_presets.cfg

# Test, capture, and debug output.
tests/results/
bug_image/
*.log
debug.log
test_output.log
check_output.txt
verify_output.txt
godot-cardgame-test.log

# Python generated files.
__pycache__/
*.py[cod]
.pytest_cache/

# OS metadata.
Thumbs.db
Desktop.ini
.DS_Store

# Local editor settings.
.vscode/
.idea/
*.tmp
*.bak
